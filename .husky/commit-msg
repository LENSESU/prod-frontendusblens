#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

MSG_FILE="$1"
MSG="$(cat "$MSG_FILE")"

# Acepta solo mensajes que empiecen por:
# [ADD]   [UPDATE]   [DELETE]   [FIX]   [EDIT]
if echo "$MSG" | grep -Eq '^\[(ADD|UPDATE|DELETE|FIX|DELETE)\].+'; then
  exit 0
fi

echo "❌ Mensaje de commit inválido."
echo "   Usa el formato: [ADD|UPDATE|DELETE|FIX|EDIT]tu descripción"
exit 1